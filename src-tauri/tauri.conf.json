{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dark Tower Open Companion",
  "version": "0.5.0",
  "identifier": "org.darktower.opencompanion.milestone4",
  "build": {
    "frontendDist": "../web"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Dark Tower: Open Companion \u2014 Native v0.5.0",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "dataDirectory": "desktop-webview-v0.5.0",
        "url": "index.html?v=0.5.0",
        "useHttpsScheme": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "shortDescription": "Open-source tabletop companion for Dark Tower",
    "longDescription": "An unofficial, noncommercial tabletop companion for the 1981 Dark Tower board game.",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    }
  }
}
